target/
Cargo.lock

# backup files generated by rustfmt
**/*.rs.bk

# editor config files and directories
*.iml
/.idea/
/.vscode/

# Web demo build output
examples/web-demo/dist/

# Python bytecode cache
**/__pycache__/
*.pyc
*.pyo

# Node.js
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
*.js.map
*.d.ts.map
.cache/

# But keep npm package source and config files
!packages/npm/**/package.json
!packages/npm/**/src/*.ts
!packages/npm/**/*.ts

# Static assets policy: ignore public folders and compiled CSS, keep SCSS in git
**/public/
*.css
!*.scss

# IDE
.DS_Store
Thumbs.db

# MCP server configs (local tooling)
.mcp.json
package.json
!packages/npm/*/package.json
!packages/browser-glue/package.json
screenshot-test.png

# W3C WebIDL cache (downloaded by fetch_w3c_idl.py)
scripts/idl-cache/
scripts/idl-cache/
