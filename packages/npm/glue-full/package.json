{
  "name": "@celestia/tairitsu-glue-full",
  "version": "0.1.0",
  "description": "Tairitsu browser glue \u2014 all WIT domain implementations aggregated",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/celestia-org/tairitsu.git",
    "directory": "packages/npm/glue-full"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@celestia/tairitsu-glue-dom": "^0.1.0",
    "@celestia/tairitsu-glue-events": "^0.1.0",
    "@celestia/tairitsu-glue-css": "^0.1.0",
    "@celestia/tairitsu-glue-html": "^0.1.0",
    "@celestia/tairitsu-glue-observers": "^0.1.0",
    "@celestia/tairitsu-glue-resize-observer": "^0.1.0",
    "@celestia/tairitsu-glue-platform": "^0.1.0",
    "@celestia/tairitsu-glue-auth": "^0.1.0",
    "@celestia/tairitsu-glue-canvas": "^0.1.0",
    "@celestia/tairitsu-glue-crypto": "^0.1.0",
    "@celestia/tairitsu-glue-device": "^0.1.0",
    "@celestia/tairitsu-glue-fetch": "^0.1.0",
    "@celestia/tairitsu-glue-file-api": "^0.1.0",
    "@celestia/tairitsu-glue-geolocation": "^0.1.0",
    "@celestia/tairitsu-glue-indexed-db": "^0.1.0",
    "@celestia/tairitsu-glue-media": "^0.1.0",
    "@celestia/tairitsu-glue-misc": "^0.1.0",
    "@celestia/tairitsu-glue-notifications": "^0.1.0",
    "@celestia/tairitsu-glue-payments": "^0.1.0",
    "@celestia/tairitsu-glue-performance": "^0.1.0",
    "@celestia/tairitsu-glue-permissions": "^0.1.0",
    "@celestia/tairitsu-glue-service-workers": "^0.1.0",
    "@celestia/tairitsu-glue-storage": "^0.1.0",
    "@celestia/tairitsu-glue-streams": "^0.1.0",
    "@celestia/tairitsu-glue-svg": "^0.1.0",
    "@celestia/tairitsu-glue-url": "^0.1.0",
    "@celestia/tairitsu-glue-wasm": "^0.1.0",
    "@celestia/tairitsu-glue-web-animations": "^0.1.0",
    "@celestia/tairitsu-glue-webrtc": "^0.1.0",
    "@celestia/tairitsu-glue-websocket": "^0.1.0",
    "@celestia/tairitsu-glue-websockets": "^0.1.0",
    "@celestia/tairitsu-glue-workers": "^0.1.0"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --platform=browser --minify --external:@celestia/tairitsu-glue-*",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "rimraf": "^5.0.0"
  }
}
