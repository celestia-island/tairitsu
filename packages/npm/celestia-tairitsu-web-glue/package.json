{
  "name": "celestia-tairitsu-web-glue",
  "version": "0.5.0",
  "description": "Tairitsu web glue — unified browser package: WIT domain glue, runtime loader, WASM bindings",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./glue": {
      "import": "./dist/glue-index.js",
      "types": "./dist/glue-index.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime-index.js",
      "types": "./dist/runtime-index.d.ts"
    },
    "./wasm/*": {
      "import": "./dist/wasm/*.js",
      "types": "./dist/wasm/*.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.wasm",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/celestia-island/tairitsu.git",
    "directory": "packages/npm/celestia-tairitsu-web-glue"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --platform=browser --minify",
    "build:dev": "esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --platform=browser",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "rimraf": "^5.0.0"
  }
}
