{
  "name": "@celestia/tairitsu-glue-core",
  "version": "0.1.0",
  "description": "Tairitsu browser glue core — shared handle tables and helpers for WIT interface implementations",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "sideEffects": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/**/*.js", "dist/**/*.d.ts", "README.md"],
  "repository": {
    "type": "git",
    "url": "https://github.com/celestia-org/tairitsu.git",
    "directory": "packages/npm/glue-core"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --platform=browser --minify && tsc --emitDeclarationOnly --outDir dist",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.5.0"
  }
}
