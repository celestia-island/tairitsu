{
  "name": "@tairitsu/browser-glue",
  "version": "0.1.0",
  "description": "Auto-generated TypeScript glue for Tairitsu browser WIT interfaces (W3C WebIDL specs)",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./handles": {
      "import": "./dist/handles.js",
      "types": "./dist/handles.d.ts"
    },
    "./async": {
      "import": "./dist/async.js",
      "types": "./dist/async.d.ts"
    },
    "./dom": {
      "import": "./dist/domGlue.js",
      "types": "./dist/domGlue.d.ts"
    },
    "./events": {
      "import": "./dist/eventsGlue.js",
      "types": "./dist/eventsGlue.d.ts"
    },
    "./fetch": {
      "import": "./dist/fetchGlue.js",
      "types": "./dist/fetchGlue.d.ts"
    },
    "./canvas": {
      "import": "./dist/canvasGlue.js",
      "types": "./dist/canvasGlue.d.ts"
    },
    "./html": {
      "import": "./dist/htmlGlue.js",
      "types": "./dist/htmlGlue.d.ts"
    },
    "./css": {
      "import": "./dist/cssGlue.js",
      "types": "./dist/cssGlue.d.ts"
    },
    "./crypto": {
      "import": "./dist/cryptoGlue.js",
      "types": "./dist/cryptoGlue.d.ts"
    },
    "./media": {
      "import": "./dist/mediaGlue.js",
      "types": "./dist/mediaGlue.d.ts"
    },
    "./performance": {
      "import": "./dist/performanceGlue.js",
      "types": "./dist/performanceGlue.d.ts"
    },
    "./storage": {
      "import": "./dist/storageGlue.js",
      "types": "./dist/storageGlue.d.ts"
    },
    "./url": {
      "import": "./dist/urlGlue.js",
      "types": "./dist/urlGlue.d.ts"
    },
    "./workers": {
      "import": "./dist/workersGlue.js",
      "types": "./dist/workersGlue.d.ts"
    },
    "./webrtc": {
      "import": "./dist/webrtcGlue.js",
      "types": "./dist/webrtcGlue.d.ts"
    },
    "./websocket": {
      "import": "./dist/websocketGlue.js",
      "types": "./dist/websocketGlue.d.ts"
    }
  },
  "scripts": {
    "build": "npm run build:glue && swc src -d dist --strip-leading-paths && tsc --emitDeclarationOnly",
    "build:production": "npm run build:glue && swc src -d dist --strip-leading-paths -C minify.compress=true -C minify.mangle=true && tsc --emitDeclarationOnly",
    "build:watch": "swc src -d dist --strip-leading-paths --watch",
    "build:glue": "python3 ../../scripts/generate_browser_glue.py",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@swc/cli": "^0.3.0",
    "@swc/core": "^1.7.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.5.0"
  }
}
