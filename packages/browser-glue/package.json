    },
    "./generated": {
      "import": "./dist/generated-index.js",
      "types": "./dist/generated-index.d.ts"
    },
    "./generated/canvas": {
      "import": "./dist/generated/canvas-glue.js",
      "types": "./dist/generated/canvas-glue.d.ts"
    },
    "./generated/crypto": {
      "import": "./dist/generated/crypto-glue.js",
      "types": "./dist/generated/crypto-glue.d.ts"
    },
