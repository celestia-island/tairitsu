    "./generated/workers": {
      "import": "./dist/generated/workers-glue.js",
      "types": "./dist/generated/workers-glue.d.ts"
    }
  },
  "scripts": {
    "build": "npm run build:glue && swc src -d dist --strip-leading-paths",
    "build:watch": "swc src -d dist --strip-leading-paths --watch",
    "build:glue": "python3 ../../scripts/generate_browser_glue.py",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@swc/cli": "^0.3.0",
    "@swc/core": "^1.7.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.5.0"
