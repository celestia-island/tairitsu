      "types": "./dist/generated/css-glue.d.ts"
    },
    "./generated/device": {
      "import": "./dist/generated/device-glue.js",
      "types": "./dist/generated/device-glue.d.ts"
    },
    "./generated/dom": {
      "import": "./dist/generated/dom-glue.js",
      "types": "./dist/generated/dom-glue.d.ts"
    },
    "./generated/events": {
      "import": "./dist/generated/events-glue.js",
