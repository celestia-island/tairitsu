{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationDir": "./dist",
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "sourceMap": true,
    "lib": ["DOM", "DOM.Iterable", "WebCrypto", "WebAudio", "FormData", "Headers", "Request", "Response", "WebSocket", "URL", "URLSearchParams"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
