/**
 * @tairitsu/browser-glue/generated
 *
 * Auto-generated TypeScript glue code for browser WIT interfaces.
 *
 * Generated by: scripts/generate_browser_glue.py
 * Source: packages/browser-worlds/wit/generated/*.wit
 *
 * DO NOT EDIT MANUALLY - regenerate with: just glue-gen
 *
 * ## Package layout
 *
{% for domain in domains -%}
 * - `./{{ domain.name }}` — `tairitsu-browser:{{ domain.name }}` interfaces ({{ domain.interface_count }} interfaces)
{% endfor -%}
 */

// Re-export all generated modules
{% for domain in domains -%}
export * as {{ domain.export_name }} from "./generated/{{ domain.name }}-glue.js";
{% endfor %}

// Export individual domain functions for convenience
{% for domain in domains -%}
export {
{%- for interface in domain.interfaces -%}
{%- for func in interface.functions %}
  {{ func.ts_name }} as {{ domain.export_name }}_{{ func.ts_name }},
{%- if func.is_async %}
  poll{{ func.pascal_name }} as {{ domain.export_name }}_poll{{ func.pascal_name }},
{%- endif -%}
{% endfor -%}
{% endfor -%}
} from "./generated/{{ domain.name }}-glue.js";
{% endfor %}

/**
 * Statistics for generated glue code.
 */
export const GLUE_STATS = {
  totalDomains: {{ domains|length }},
  totalInterfaces: {{ total_interfaces }},
  totalFunctions: {{ total_functions }},
  generatedAt: "{{ generated_at }}",
};
